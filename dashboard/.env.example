# Database Connection (use Supabase/Neon connection string with pooling)
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB?pgbouncer=true&connect_timeout=15

# Optional: Direct connection for migrations (without pooling)
DIRECT_URL=postgresql://USER:PASS@HOST:5432/DB

# NextAuth.js Configuration
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-32-character-random-secret-key-here

# Agent Backend URL (Cloudflare Tunnel or public URL)
AGENT_URL=https://your-agent-cloudflare-tunnel.trycloudflare.com

# Admin User (for seeding database)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password-here

# Optional: Telegram notification (if agent uses it)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
